APP_NAME=ETAC Backend
APP_ENV=dev
HAPPYROBOT_BASE_URL=https://platform.eu.happyrobot.ai/api/v2
HAPPYROBOT_API_KEY=sk_live_xxx
HAPPYROBOT_TIMEOUT_SECONDS=20
# Browser CORS: "*" = any origin (default, good for Render + separate frontend host).
# Or comma list: https://your-app.vercel.app,https://www.example.com
CORS_ORIGINS=*
# Lead booking (HappyRobot webhook → slots → email link). Set PUBLIC_APP_BASE_URL to your Vercel URL.
PUBLIC_APP_BASE_URL=
BOOKING_WEBHOOK_SECRET=
BOOKING_SERVICE_SECRET=
HAPPYROBOT_OUTBOUND_WEBHOOK_URL=
